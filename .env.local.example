# Supabase – create free project at supabase.com
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Resend – create free account at resend.com
RESEND_API_KEY=re_xxxx
EMAIL_FROM=noreply@yourdomain.com

# Shopify webhook secret – found in Shopify Admin > Settings > Notifications > Webhooks
SHOPIFY_WEBHOOK_SECRET=your-webhook-secret

# Your app's public URL (used in emails)
NEXT_PUBLIC_APP_URL=https://your-vercel-app.vercel.app

# Your Shopify product checkout URL
NEXT_PUBLIC_SHOPIFY_PRODUCT_URL=https://your-shop.myshopify.com/products/grundriss-check
